# ===== Database (PostgreSQL + pgvector) =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ragdb
DB_USER=postgres
DB_PASSWORD=change-me

# ===== Ollama LLM =====
OLLAMA_BASE_URL=http://localhost:11434
SUMMARIZATION_MODEL=qwen3.5:4b
GENERATION_MODEL=qwen3.5:4b
SUMMARIZATION_TEMPERATURE=0.3
GENERATION_TEMPERATURE=0.1

# ===== Embedding =====
EMBEDDING_MODEL_NAME=blaifa/multilingual-e5-large-instruct:Q8_0

# ===== App Settings =====
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
MAX_CONCURRENCY=3
MAX_CHARACTERS=3000
NEW_AFTER_N_CHARS=2500
COMBINE_TEXT_UNDER_N_CHARS=500
MIN_CHUNK_SIZE_FOR_MERGE=200
TOP_K_RETRIEVAL=5
CHAT_HISTORY_DEPTH=6
# UPLOAD_DIR and IMAGE_DIR are advanced overrides (absolute paths).
# Defaults derive from backend/app/config.py — no need to set these.
